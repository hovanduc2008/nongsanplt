<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏡 Nông Sản Play Together</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- FONT -->
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: #e8f5e9;
            font-family: 'Quicksand', sans-serif;
        }

        /* HEADER */
        .farm-header {
            background: #795548;
            color: white;
            padding: 35px 20px;
            border-bottom: 10px solid #5d4037;
            border-radius: 0 0 40px 40px;
            margin-bottom: 25px;
            text-align: center;
        }

        /* FILTER */
        .filter-box {
            background: white;
            padding: 20px;
            border-radius: 25px;
            box-shadow: 0 8px 0 #c8e6c9;
            margin-bottom: 30px;
        }

        /* PRODUCT */
        .product-card {
            background: white;
            border-radius: 30px;
            box-shadow: 0 10px 0 #c8e6c9;
            height: 100%;
            transition: .15s;
        }

        .product-card:hover {
            transform: translateY(-4px);
        }

        .img-box {
            background: #fff9c4;
            height: 180px;
            display: flex;
            justify-content: center;
            align-items: center;
            border-radius: 30px 30px 0 0;
        }

        .badge-he {
            background: #f1f8e9;
            padding: 6px 14px;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.85rem;
            display: inline-block;
        }

        .price {
            font-size: 1.4rem;
            font-weight: 700;
            color: #ff5252;
        }

        .btn-buy {
            background: #4CAF50;
            color: white;
            border-radius: 20px;
            padding: 10px;
            border: none;
            font-weight: 700;
            width: 100%;
        }

        .btn-buy:active {
            transform: translateY(2px);
        }

        .btn-disabled {
            background: #bdbdbd !important;
            cursor: not-allowed;
        }
    </style>
</head>
<body>

<!-- HEADER -->
<div class="farm-header">
    <h1>🏡 Play Together Farm 🌾</h1>
    <p class="mb-0">Sản phẩm Play Together</p>
</div>

<!-- CART -->
<div class="text-center mb-4">
    <a href="/cart" class="btn btn-success rounded-pill fw-bold px-4">
        🛒 XEM GIỎ HÀNG
    </a>
</div>

<!-- FILTER -->
<div class="container">
    <div class="filter-box">
        <div class="row g-3">
            <div class="col-md-6">
                <select id="filterProduct" class="form-select fw-bold">
                    <option value="">🌾 Tất cả nông sản</option>
                    <% [...new Set(products.map(p => p.name))].forEach(name => { %>
                        <option value="<%= name %>"><%= name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-6">
                <select id="filterVariant" class="form-select fw-bold">
                    <option value="">🎨 Tất cả biến thể</option>
                    <% [...new Set(products.map(p => p.he))].forEach(he => { %>
                        <option value="<%= he %>"><%= he %></option>
                    <% }) %>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- PRODUCT LIST -->
<div class="container">
    <div class="row g-4">

        <% products.forEach(p => { %>
        <div class="col-md-4 col-sm-6 product-wrapper"
             data-product="<%= p.name %>"
             data-variant="<%= p.he %>">

            <div class="product-card">
                <div class="img-box">
                    <img src="<%= p.img %>" alt="<%= p.name %>" height="110">
                </div>

                <div class="p-4 text-center">
                    <span class="badge-he"><%= p.icon %> <%= p.he %></span>

                    <h5 class="fw-bold mt-2 text-success">
                        <%= p.name %>
                    </h5>

                    <div class="price">
                        <%= p.price.toLocaleString() %>đ
                    </div>

                    <p class="text-muted fw-bold">
                        Còn lại: <%= p.quantity %>
                    </p>

                    <% if (p.quantity > 0) { %>
                        <form action="/add-to-cart/<%= p.pv_id %>" method="POST">
                            <button type="submit" class="btn-buy">
                                🌾 THU HOẠCH
                            </button>
                        </form>
                    <% } else { %>
                        <button class="btn-buy btn-disabled" disabled>
                            HẾT HÀNG
                        </button>
                    <% } %>
                </div>
            </div>

        </div>
        <% }) %>

    </div>
</div>

<!-- FILTER SCRIPT -->
<script>
const productSelect = document.getElementById('filterProduct');
const variantSelect = document.getElementById('filterVariant');
const items = document.querySelectorAll('.product-wrapper');

function filterProducts() {
    const pVal = productSelect.value;
    const vVal = variantSelect.value;

    items.forEach(item => {
        const okP = !pVal || item.dataset.product === pVal;
        const okV = !vVal || item.dataset.variant === vVal;
        item.style.display = (okP && okV) ? '' : 'none';
    });
}

productSelect.addEventListener('change', filterProducts);
variantSelect.addEventListener('change', filterProducts);
</script>

</body>
</html>
