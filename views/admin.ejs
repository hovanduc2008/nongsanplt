<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🛠 Admin Nông Trại Play Together</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: #e8f5e9;
            font-family: 'Quicksand', sans-serif;
        }

        .admin-header {
            background: #795548;
            color: white;
            padding: 40px 20px;
            border-bottom: 10px solid #5d4037;
            text-align: center;
            border-radius: 0 0 40px 40px;
            margin-bottom: 50px;
        }

        .admin-header h1 {
            font-weight: 700;
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        .admin-container {
            max-width: 600px;
            margin: 0 auto;
        }

        .admin-card {
            background: white;
            border-radius: 25px;
            padding: 30px;
            box-shadow: 0 12px 0 #c8e6c9;
            text-align: center;
            transition: transform 0.2s;
            margin-bottom: 30px;
        }

        .admin-card:hover {
            transform: translateY(-5px);
        }

        .admin-card h3 {
            color: #2e7d32;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .admin-card a {
            display: inline-block;
            background: #4CAF50;
            color: white;
            padding: 12px 25px;
            border-radius: 20px;
            font-weight: 700;
            text-decoration: none;
            transition: background 0.2s;
        }

        .admin-card a:hover {
            background: #66bb6a;
        }
    </style>
</head>
<body>

<div class="admin-header">
    <h1>🛠 Admin Nông Trại</h1>
    <p>Quản lý sản phẩm và đơn hàng Play Together</p>
</div>

<div class="admin-container">
    <!-- Quản lý Product Variants -->
    <div class="admin-card">
        <h3>🛒 Quản lý Product Variants</h3>
        <a href="/admin/product-variants">➡ Vào trang</a>
    </div>

    <!-- Quản lý Orders -->
    <div class="admin-card">
        <h3>📦 Quản lý Đơn Hàng</h3>
        <a href="/admin/orders">➡ Vào trang</a>
    </div>
</div>

</body>
</html>
