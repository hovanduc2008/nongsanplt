<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>🛠 Quản lý Đơn Hàng</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: #e8f5e9;
            font-family: 'Quicksand', sans-serif;
        }

        .box {
            background: white;
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 12px 0 #c8e6c9;
        }

        h2 {
            font-weight: 700;
            color: #2e7d32;
        }

        table th {
            background: #4CAF50;
            color: white;
        }

        select, input {
            border-radius: 12px !important;
        }

        .badge-status {
            padding: 4px 12px;
            border-radius: 15px;
            font-weight: 700;
            color: white;
        }

        .pending { background: #ff9800; }
        .processing { background: #2196f3; }
        .completed { background: #4caf50; }
        .cancelled { background: #f44336; }

        .search-box {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="box">
        <h2>🛠 Quản lý Đơn Hàng</h2>

        <!-- 🔍 TÌM KIẾM & LỌC -->
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <input type="text" id="searchOrder" class="form-control" placeholder="Tìm kiếm theo mã đơn...">
            </div>
            <div class="col-md-6">
                <select id="filterStatus" class="form-select">
                    <option value="">🌟 Tất cả trạng thái</option>
                    <option value="pending">Chờ</option>
                    <option value="processing">Đang xử lý</option>
                    <option value="completed">Thành công</option>
                    <option value="cancelled">Hủy</option>
                </select>
            </div>
        </div>

        <!-- 📋 BẢNG ĐƠN HÀNG -->
        <table class="table table-bordered text-center mt-2" id="ordersTable">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Người chơi</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Sản phẩm</th>
                    <th>Tổng tiền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% orders
                    .sort((a, b) => new Date(b.created_at) - new Date(a.created_at))
                    .forEach(order => { 
                        const items = orderItems.filter(i => i.order_id === order.id);
                        const total = items.reduce((sum,i)=>sum+i.price*i.quantity,0);
                %>
                <tr data-status="<%= order.status %>">
                    <td class="order-id"><%= order.id %></td>
                    <td><%= order.player_name %></td>
                    <td>
                        <span class="badge-status <%= order.status %>"><%= order.status %></span>
                    </td>
                    <td><%= new Date(order.created_at).toLocaleString() %></td>
                    <td class="text-start">
                        <ul class="list-unstyled mb-0">
                            <% items.forEach(item => { %>
                                <li><%= item.product_name %> (<%= item.variant %>) x <%= item.quantity %></li>
                            <% }) %>
                        </ul>
                    </td>
                    <td><%= total.toLocaleString() %>đ</td>
                    <td>
                        <form action="/admin/orders/update/<%= order.id %>" method="POST" class="d-flex gap-2 justify-content-center">
                            <select name="status" class="form-select form-select-sm" required>
                                <option value="pending" <%= order.status==='pending'?'selected':'' %>>Chờ</option>
                                <option value="processing" <%= order.status==='processing'?'selected':'' %>>Đang xử lý</option>
                                <option value="completed" <%= order.status==='completed'?'selected':'' %>>Thành công</option>
                                <option value="cancelled" <%= order.status==='cancelled'?'selected':'' %>>Hủy</option>
                            </select>
                            <button class="btn btn-warning btn-sm">💾</button>
                        </form>
                    </td>
                </tr>
                <% }) %>

            </tbody>
        </table>

        <a href="/admin" class="btn btn-secondary mt-3">Quay lại</a>
    </div>
</div>

<script>
    const searchInput = document.getElementById('searchOrder');
    const filterStatus = document.getElementById('filterStatus');
    const tableRows = Array.from(document.querySelectorAll('#ordersTable tbody tr'));

    function filterOrders() {
        const term = searchInput.value.toLowerCase();
        const statusVal = filterStatus.value;

        tableRows.forEach(row => {
            const id = row.querySelector('.order-id').textContent.toLowerCase();
            const status = row.dataset.status;

            const matchSearch = id.includes(term);
            const matchStatus = !statusVal || status === statusVal;

            row.style.display = (matchSearch && matchStatus) ? '' : 'none';
        });
    }

    searchInput.addEventListener('input', filterOrders);
    filterStatus.addEventListener('change', filterOrders);
</script>

</body>
</html>
