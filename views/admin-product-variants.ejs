<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>🛠 Quản lý Nông Sản</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&display=swap" rel="stylesheet">

    <style>
        body {
            background: #e8f5e9;
            font-family: 'Quicksand', sans-serif;
        }

        .box {
            background: white;
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 12px 0 #c8e6c9;
        }

        h2 {
            font-weight: 700;
            color: #2e7d32;
        }

        table th {
            background: #4CAF50;
            color: white;
        }

        input, select {
            border-radius: 12px !important;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="box">

        <h2>🛠 Quản lý Product Variants</h2>

        <!-- ➕ THÊM -->
        <form action="/admin/product-variants/add" method="POST" class="row g-2 my-4">
            <div class="col-md-3">
                <select name="product_id" class="form-control" required>
                    <% products.forEach(p => { %>
                        <option value="<%= p.id %>"><%= p.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-3">
                <select name="variant_id" class="form-control" required>
                    <% variants.forEach(v => { %>
                        <option value="<%= v.id %>"><%= v.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="col-md-2">
                <input type="number" name="price" class="form-control" placeholder="Giá" required>
            </div>

            <div class="col-md-2">
                <input type="number" name="quantity" class="form-control" placeholder="SL" required>
            </div>

            <div class="col-md-2">
                <button class="btn btn-success w-100">➕ Thêm</button>
            </div>
        </form>

        <!-- 📋 DANH SÁCH -->
        <table class="table table-bordered text-center">
            <thead>
                <tr>
                    <th>Nông sản</th>
                    <th>Biến thể</th>
                    <th>Giá</th>
                    <th>Tồn</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% list.forEach(i => { %>
                <tr>
                    <form action="/admin/product-variants/update/<%= i.id %>" method="POST">
                        <td><%= i.product %></td>
                        <td><%= i.variant %></td>
                        <td>
                            <input type="number" name="price" value="<%= i.price %>" class="form-control">
                        </td>
                        <td>
                            <input type="number" name="quantity" value="<%= i.quantity %>" class="form-control">
                        </td>
                        <td class="d-flex gap-2 justify-content-center">
                            <button class="btn btn-warning btn-sm">💾</button>
                    </form>
                    <form action="/admin/product-variants/delete/<%= i.id %>" method="POST">
                        <button class="btn btn-danger btn-sm">🗑</button>
                    </form>
                        </td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <a href="/admin" class="btn btn-secondary mt-3">Quay lại</a>

    </div>
</div>

</body>
</html>
