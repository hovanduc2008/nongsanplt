<!DOCTYPE html>
<html lang="vi">
<head>
    <title><%= product.name %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container py-5">
        <a href="/" class="btn btn-outline-secondary mb-3">← Quay lại</a>
        <div class="row mt-4">
            <div class="col-md-6">
                <img src="<%= product.img %>" class="img-fluid rounded shadow" alt="...">
            </div>
            <div class="col-md-6">
                <h1 class="text-success"><%= product.name %></h1>
                <hr>
                <h5>Phân loại: <span class="text-primary"><%= product.he %></span></h5>
                <h3 class="text-danger my-3">Giá: <%= product.price %></h3>
                <p class="lead"><%= product.desc %></p>
                <button class="btn btn-warning btn-lg">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>
</body>
</html>